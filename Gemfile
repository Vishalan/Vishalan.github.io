source "https://rubygems.org"

# Local preview only. GitHub Pages builds the published site with its own
# server-side gem set, so this Gemfile does not affect production.
# The blog uses only standard, widely-supported features, so a local build
# with modern Jekyll matches what GitHub Pages produces.
gem "jekyll", "~> 4.3"
gem "jekyll-feed", "~> 0.17"
gem "jekyll-seo-tag", "~> 2.8"

# Ruby 3.0+ no longer ships webrick, which `jekyll serve` needs.
gem "webrick", "~> 1.8"
